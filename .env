# ── Serveur ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Origines autorisées par CORS (séparées par virgule).
# Inclure :
# - localhost:5500 / 127.0.0.1:5500 → Live Server (VS Code)
# - localhost:3000 / 127.0.0.1:3000 → frontend servi par ce backend
# - localhost:8080 → http-server, Python http.server, etc.
FRONTEND_URL=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080

# Cookies : forcer secure + sameSite=none même en dev (utile si HTTPS local)
# COOKIE_SECURE=true

# ── Base de données MySQL ─────────────────────────────────────
# Modifiez ces valeurs avec vos identifiants HeidiSQL / MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=ccs_user
DB_PASSWORD=CCS_Salouel_2025!
DB_NAME=ccs_salouel

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=CCS_Salouel_JWT_Secret_2025_XkP9mNvQwRtY
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CCS_Salouel_Refresh_2025_ZhB3cLdWsEfG
JWT_REFRESH_EXPIRES_IN=7d

# ── Email (Nodemailer) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@club-salouel.fr
SMTP_PASS=votre_mot_de_passe_app_gmail
EMAIL_FROM=Club de Cyclisme de Salouel <contact@club-salouel.fr>
EMAIL_ADMIN=president@club-salouel.fr

# ── Upload ────────────────────────────────────────────────────
MAX_GPX_SIZE_MB=10
UPLOADS_DIR=./uploads

# ── Google Maps (optionnel — Street View reel) ───────────────
# https://console.cloud.google.com -> APIs -> Maps JavaScript API + Street View
GOOGLE_MAPS_KEY=

# ── Mapillary (optionnel — street view communautaire) ────────
# https://www.mapillary.com/developer
MAPILLARY_TOKEN=
