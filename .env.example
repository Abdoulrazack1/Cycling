# ── Serveur ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# ── Base de données MySQL ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=ccs_user
DB_PASSWORD=votre_mot_de_passe_ici
DB_NAME=ccs_salouel

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=votre_secret_jwt_32_caracteres_minimum
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=votre_refresh_secret_different
JWT_REFRESH_EXPIRES_IN=7d

# ── Email (Nodemailer) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@club-salouel.fr
SMTP_PASS=votre_mot_de_passe_app
EMAIL_FROM=C.C. Salouel <contact@club-salouel.fr>
EMAIL_ADMIN=president@club-salouel.fr

# ── Upload ────────────────────────────────────────────────────
MAX_GPX_SIZE_MB=10
UPLOADS_DIR=./uploads
