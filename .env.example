# ── Serveur ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Niveau de log pino : trace | debug | info | warn | error | fatal
# En dev, sortie pino-pretty colorée ; en prod, JSON brut parsable.
LOG_LEVEL=info
# Origines autorisées par CORS (séparées par virgule).
# En dev, le code autorise déjà tous les localhost/127.0.0.1.
# En prod, mettre uniquement le(s) domaine(s) frontend autorisé(s).
FRONTEND_URL=http://localhost:5500

# ── Base de données MySQL ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=ccs_user
DB_PASSWORD=votre_mot_de_passe_ici
DB_NAME=ccs_salouel

# ── JWT ───────────────────────────────────────────────────────
# IMPORTANT : générer des secrets uniques de ≥ 32 caractères :
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Le serveur REFUSE de démarrer si ces variables manquent ou sont trop courtes.
JWT_SECRET=remplacer_par_un_secret_genere_aleatoirement_min_32_chars
JWT_REFRESH_SECRET=DIFFERENT_du_precedent_genere_aleatoirement_min_32_chars
# TTL : 15m / 30d est l'équilibre conseillé.
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (Nodemailer) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@club-salouel.fr
SMTP_PASS=votre_mot_de_passe_app
EMAIL_FROM=C.C. Salouel <contact@club-salouel.fr>
EMAIL_ADMIN=president@club-salouel.fr

# ── Strava OAuth ──────────────────────────────────────────────
# Pour activer l'import des activités Strava des membres :
# 1. Crée une app sur https://www.strava.com/settings/api
# 2. Configure :
#    - Authorization Callback Domain : localhost (dev) ou ton domaine prod
#    - Website : URL de prod
# 3. Copie le Client ID + Client Secret ici
# 4. STRAVA_REDIRECT_URI doit matcher EXACTEMENT ce que tu configures sur Strava
#    (le path est /api/strava/callback)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback

# ── Upload ────────────────────────────────────────────────────
MAX_GPX_SIZE_MB=10
UPLOADS_DIR=./uploads

# ── OSRM (routage cyclable) ──────────────────────────────────
# Par défaut, l'instance publique est utilisée — peut être lente / 503.
# Pour un usage soutenu, déployer une instance OSRM locale.
# OSRM_BASE=http://localhost:5000

# ── Audit log (Brief B5) ─────────────────────────────────────
# Rétention des entrées dans la table audit_log. Minimum 30 jours.
# Le serveur purge automatiquement les entrées plus anciennes une fois par mois.
AUDIT_RETENTION_DAYS=365

# ── Backups MySQL ─────────────────────────────────────────────
# Dossier de destination + rétention. Voir scripts/backup-db.js.
# À planifier en cron / Tâches planifiées Windows (cf. commentaire en tête du script).
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
# Override optionnel du chemin mysqldump. Si vide, le script cherche
# dans le PATH puis dans C:\laragon\bin\mysql\... (Windows).
# MYSQLDUMP_PATH=C:\laragon\bin\mysql\mysql-8.4.3-winx64\bin\mysqldump.exe

