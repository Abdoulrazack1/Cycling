{
  "name": "ccs-salouel-backend",
  "version": "1.0.1",
  "description": "Club de Cyclisme de Salouel — API REST complète",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node seed.js",
    "test": "node --test --test-concurrency=1 tests/scraper.test.js tests/integration/auth.test.js tests/integration/sorties.test.js tests/integration/admin.test.js tests/integration/gpx.test.js tests/integration/twofa.test.js tests/integration/stats.test.js tests/integration/newsletter.test.js tests/integration/public-endpoints.test.js tests/integration/journey.test.js tests/integration/my-dashboard.test.js",
    "test:unit": "node --test tests/scraper.test.js",
    "test:integration": "node --test --test-concurrency=1 tests/integration/auth.test.js tests/integration/sorties.test.js tests/integration/admin.test.js tests/integration/gpx.test.js tests/integration/twofa.test.js tests/integration/stats.test.js tests/integration/newsletter.test.js tests/integration/public-endpoints.test.js tests/integration/journey.test.js tests/integration/my-dashboard.test.js",
    "scrape": "node scripts/scrape-sorties.js --osm",
    "scrape:save": "node scripts/scrape-sorties.js --osm --save-db",
    "scrape:osm": "node scripts/scrape-sorties.js --osm --save-db",
    "scrape:full": "node scripts/scrape-sorties.js --osm --milesrepublic --save-db",
    "clean": "node scripts/clean-sorties.js",
    "expire": "node scripts/expire-past-sorties.js",
    "expire:dry": "node scripts/expire-past-sorties.js --dry",
    "audit:purge": "node scripts/purge-audit-log.js",
    "audit:purge:dry": "node scripts/purge-audit-log.js --dry",
    "backup": "node scripts/backup-db.js && node scripts/backup-cleanup.js",
    "backup:cleanup": "node scripts/backup-cleanup.js",
    "backup:cleanup:dry": "node scripts/backup-cleanup.js --dry",
    "migrate": "node scripts/migrate.js",
    "migrate:status": "node scripts/migrate.js --status",
    "migrate:dry": "node scripts/migrate.js --dry-run",
    "app": "electron electron-main.js",
    "app:dir": "electron-builder --dir",
    "app:dist": "electron-builder"
  },
  "dependencies": {
    "bcryptjs": "^3.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0",
    "mysql2": "^3.6.5",
    "nodemailer": "^8.0.7",
    "otplib": "^13.4.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "uuid": "^11.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "nodemon": "^3.0.2",
    "pino-pretty": "^13.1.3"
  },
  "build": {
    "appId": "fr.cc-salouel.desktop",
    "productName": "Club de Cyclisme de Salouel",
    "extraMetadata": { "main": "electron-main.js" },
    "asar": false,
    "directories": { "output": "dist-desktop" },
    "files": [
      "**/*",
      "!dist-desktop/**",
      "!.git/**",
      "!.github/**",
      "!.claude/**",
      "!.vscode/**",
      "!screenshots/**",
      "!promo/**",
      "!backups/**",
      "!tests/**",
      "!test/**",
      "!docs/**",
      "!**/*.md"
    ],
    "win": {
      "target": "nsis",
      "icon": "asset/img/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Club de Cyclisme de Salouel"
    }
  }
}
