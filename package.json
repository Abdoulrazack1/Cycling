{
  "name": "ccs-salouel-backend",
  "version": "1.0.1",
  "description": "Club de Cyclisme de Salouel — API REST complète",
  "main": "server.js",
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "test": "node --test tests/scraper.test.js tests/integration/",
    "test:unit": "node --test tests/scraper.test.js",
    "test:integration": "node --test tests/integration/",
    "scrape": "node scripts/scrape-sorties.js --osm",
    "scrape:save": "node scripts/scrape-sorties.js --osm --save-db",
    "scrape:osm": "node scripts/scrape-sorties.js --osm --save-db",
    "scrape:full": "node scripts/scrape-sorties.js --osm --milesrepublic --save-db",
    "clean": "node scripts/clean-sorties.js",
    "expire": "node scripts/expire-past-sorties.js",
    "expire:dry": "node scripts/expire-past-sorties.js --dry",
    "audit:purge": "node scripts/purge-audit-log.js",
    "audit:purge:dry": "node scripts/purge-audit-log.js --dry",
    "backup": "node scripts/backup-db.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0",
    "mysql2": "^3.6.5",
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "pino-pretty": "^13.1.3"
  }
}
